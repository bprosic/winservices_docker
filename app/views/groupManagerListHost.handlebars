<body>
    <div class="d-flex" id="wrapper">
        {{>sidebar}}
        <!-- Page Content -->

        <div id="page-content-wrapper">

            <!-- breadcrumb -->
            <div class="row">
                <div class="col-xs-12">
                    <div class="col-xs-12">

                        <ul class="breadcrumb">
                            <i class="icon icon-location"></i>
                            <li class="breadcrumb-item">
                                <a href="/addhost">Group manager</a>
                            </li>
                            <li class="breadcrumb-item">
                                <a id="breadcrumbCurrent" href="#">Add host</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="container-fluid">
                <div class="row">
                    <div class="col-xs-12">
                        {{#each userData}}
                        <h4>Add a client (for group <span class="text-primary">'{{uUsername}}'):</h4>
                        
                        {{/each}}
                        <form id="addhostform" data-toggle="validator" role="form" method="POST"
                            action="/addhost/insert">
                            <input type="hidden" id="csrf" name="_csrf" value="{{csrfToken}}">
                            <div class="addForm">
                                <div class="form-row" id="macAddrInputContainer">
                                    <label for="hostMac">MAC Address <a id="helpMacBtn" href="#"><span
                                                class="chip">?</span></a>
                                        <small class="label label-warning">important to fill</small></label>
                                    <input type="text" class="form-control" id="hostMac" placeholder="Host MAC Address"
                                        required>
                                </div>
                                <div class="form-row">
                                    <label for="ipHostname">Computer name <small class="label">optional</small></label>
                                    <input type="text" class="form-control" id="ipHostname" placeholder="Hostname">
                                </div>
                                <div class="form-row" id="hostDescriptionInputContainer">
                                    <label for="hostDescription">Description <small
                                            class="label">optional</small></label>
                                    <input type="text" class="form-control" id="hostDescription"
                                        placeholder="Host Description?">
                                </div>
                            </div>
                        </form>

                        <form action="/addhost/upload" enctype="multipart/form-data" method="POST" id="imageForm">
                            <div class="addForm">
                                <div class="form-row" id="image">
                                    <div id="drop">
                                        <label for="hostImage">Image <small class="label">optional</small></label>
                                        <input type="file" name="someBild" class="form-control" accept="image/*" />
                                    </div>
                                    <div id="img-container">
                                    </div>
                                </div>
                            </div>
                        </form>
                        
                        <form>
                        
                        <h1></h1>
                        <div class="form-row"></div>
                            <button id="btnAdd" type="submit" class="btn btn-primary">Add</button>
                            <button id="btnCancel" type="reset" class="btn btn-default">Cancel</button>
                        </div>
                        </form>



                    </div>
                </div>
                <div class="container-fluid">
                <div class="row">

                    <div class="col-xs-9">
                        <h1></h1>
                        <h4>Existing hosts to monitor</h4>
                    </div>
                    <div class="col-xs-9">
                        <div id="hostsTblContainer">
                            <table id="tblUsrs" class="table table-bordered table-striped table-hover table-condensed">
                                <thead>
                                    <tr>
                                        <th class="col-md-2">MAC</th>
                                        <th class="col-md-6">Hostname</th>
                                        <th class="col-md-2">Description</th>
                                        <th class="col-md-2" style="text-align: center;">Token</th>
                                        <th class="col-md-2" style="text-align: center;">Edit</th>
                                        <th class="col-md-2" style="text-align: center;">Delete</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    {{#each hosts}}
                                    <tr>
                                        <td class="col-md-2">{{macHelper host_mac_addr}}</td>
                                        <td class="col-md-6">{{hostName}}</td>
                                        <td class="col-md-6">{{hostDescription}}</td>

                                        <td class="col-md-2" style="text-align: center;"><button type="button" name="{{idHost}}" mac="{{host_mac_addr}}"
                                                class="btn btn-link token">view</button></td>
                                        <td class="col-md-2" style="text-align: center;"><button type="button" name="{{idHost}}"
                                                class="btn btn-link ed">edit</button></td>
                                        <td class="col-md-2" style="text-align: center;"><button type="button" name="{{idHost}}"
                                                class="btn btn-link del">delete</button></td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div><!-- end div class row -->
                </div>
            </div>
            <!-- /container-fluid -->
        </div>
        <!-- /#page-content-wrapper -->
    </div>
    <!-- /#wrapper -->


    <div class="modal" id="modal-help">
        <a href="#" class="modal-overlay closemodalhelper" aria-label="Close"></a>
        <div class="modal-container">
            <div class="modal-header">
                <a href="#" class="btn btn-clear float-right closemodalhelper" aria-label="Close"></a>
                <div class="modal-title h5">MAC Address - what is it and how to obtain?</div>
            </div>
            <div class="modal-body">
                <div class="content">
                    A MAC address is a unique identifier assigned to a network interface controller (NIC) 
                    for use as a network address in communications within a network segment.
                </div>
                <div class="content">
                    <p>Enter MAC Address from a Wifi or Ethernet Network card on which network connection presides!</p>
                    <p>To check MAC address, open console or terminal on your client and write down commands:</p>
                    <p>For Windows: <code>ipconfig /all</code></p>
                    <p>For Linux: <code>ifconfig -a</code></p>
                </div>
            </div>
            <div class="modal-footer">
                <small>In future you will be able to write many MAC addresses. This is still in development</small>
            </div>
        </div>
    </div>


 <div class="modal" id="modal-token">
        <a href="#" class="modal-overlay closemodalhelper" aria-label="Close"></a>
        <div class="modal-container">
            <div class="modal-header">
                <a href="#" class="btn btn-clear float-right closemodalhelper" aria-label="Close"></a>
                <div class="modal-title h5">Client Access Token</div>
            </div>
            <div class="modal-body">
                <div class="content">
                    <p>Access token generated!<br />
                    Use this token for client program in order to gain access to this portal.</p>
                    
                    
                </div>
                <div class="modal-token-content">
                    {{!-- here will be token shown --}}
                </div>
                <p>Without token, client software cannot connect to this portal!</p>
            </div>
            <div class="modal-footer">
                <small>2026 WinService Client Token</small>
            </div>
        </div>
    </div>



    {{>logout}}
    <script src="/js/validator.js" ></script>
    <script src="/js/vendor/jquery.ui.widget.js"></script>
    <script src="/js/jquery.iframe-transport.js"></script>
    <script src="/js/jquery.fileupload.js"></script>

    <script type="application/javascript" nonce="{{nonce}}">
        // create a div called confirm box
        var confirmBoxDiv = "<div id='confirmBox'><div class='message'></div><span class='yes'>Yes</span><span class='no'>No</span></div>";

        $('#helpMacBtn').on('click', function (e) {
            e.preventDefault();
            if ($('#modal-help').hasClass('active')) {
                $('#modal-help').removeClass('active');
            } else {
                $('#modal-help').addClass('active');
            }
            
        });
        $('.closemodalhelper').on('click', function (e) {
            e.preventDefault();
            if ($('#modal-help').hasClass('active')) {
                $('#modal-help').removeClass('active');
            } 
            if ($("#modal-token").hasClass("active")) {
                $("#modal-token").removeClass("active");
                 $(".p-token").remove();
            } 
        });
        
        
          
        
        // reset forms
        $('#addhostform, #imageForm').trigger("reset");
        $('body').append(confirmBoxDiv);
        $('#addhostlnk').css({ "background-color": "#f2f2f2" });
        var userName = "";
        {{#each userData}}
        userName = "{{uUsername}}";
        {{/each}}

        {{#if errors }}
        {{#each errors }}
        {{#each this }}
        var divId = "{{param}}";
        var divOldValue = "{{value}}"
        var divWhatIsMessage = "{{msg}}";
        $('#' + divId).val(divOldValue);
        $('#' + divId).next().text(divWhatIsMessage);
        {{/each}}
        {{/each}}
        {{/if}}

    var dataToSend = "";
    var protocoll = "";
    var urlToSendTo = "";
    
    var hostName = $('#ipHostname').val();
    var hostDescription = $('#hostDescription').val();
    var hostMac = $("#hostMac").val();
    var ip = $('#inputIp');
    var csrfToken = $("[name='_csrf']").val();



    $('.ed, .del, .token').on('click', function (e) {
        e.preventDefault();
        const thisBtn = $(this);
        const hostId = thisBtn.attr('name');
        const mac = thisBtn.attr('mac');


        if (thisBtn.hasClass('token')) {
            urlToSendTo = "/edit/generate/token/host";
            protocoll = "POST";
            hostMacAddr = $("#hostMac").val();
            dataToSend = { user: userName, hostId: hostId, hostMacAddr: mac, _csrf: csrfToken };
            execAjax(urlToSendTo, protocoll, dataToSend);
            return;
        }

        if (thisBtn.hasClass('ed')) {
            console.log("clicked edit");
            console.log("/edit/host/byid/" + userName + "/" + hostId);
            window.location.href = "/edit/host/byid/" + userName + "/" + hostId; //http://192.168.162.18:50123/edit/user/hostid/
            return;
        }
        if (thisBtn.hasClass('del')) {
            urlToSendTo = "/delete/host";
            protocoll = "POST";
            dataToSend = { user: userName, hostId: hostId, _csrf: csrfToken };
            var msgToUser = "Sure to delete host?";
            // dialogbox
            doConfirm(msgToUser, $('body'), function yes() {
                //return;
                execAjax(urlToSendTo, protocoll, dataToSend);
            }, function no() {
                return;
            });
            return;

        }
    });
    
    // learn here
    // https://www.yamicode.com/snippets/upload-file-using-multer-node-express-js

    $('#btnAdd').on('click', function (e) {
        e.preventDefault();

        protocoll = "POST";
        urlToSendTo = "/addhost/insert";
        // check if mac address is still ok
        hostName = $('#ipHostname').val();
        hostDescription = $('#hostDescription').val();
        hostMacAddr = $("#hostMac").val();
        hostName = (hostName.length == 0) ? "n/a" : hostName; 
        hostDescription = (hostDescription.length == 0) ? "n/a" : hostDescription;
        //var fileName = $('#hostImage').files[0].name;

        if (!isMacAddressValid(hostMacAddr)) {
            $.notify("Invalid MAC address", "error");
            $("#hostMac").focus();
            return;
        }
        if (hostMacAddr === "00:00:00:00:00:00") {
            $.notify("MAC can't be zeroes", "error");
            $("#hostMac").focus();
            return;
        }
       
        var dataToSend = {
            user: userName,
            hostMacAddr: hostMacAddr,
            hostName: hostName,
            hostDescription: hostDescription,
            _csrf: csrfToken
        };

        execAjax(urlToSendTo, protocoll, dataToSend);
        
    });


    $('#btnCancel').on('click', function (e) {
        e.preventDefault();
        window.location.href = '/addhost';
    });

    $('#hostMac').keydown(function (event) {
        // Allow Only: keyboard 0-9, numpad 0-9, letters a-f, backspace, tab, left arrow, right arrow, delete, dash and double-dots
        /*
        https://css-tricks.com/snippets/javascript/javascript-keycodes
        */
        if ((event.keyCode >= 48 && event.keyCode <= 57) || // 0-9
            (event.keyCode >= 96 && event.keyCode <= 105) ||  // 0-9
            (event.keyCode >= 65 && event.keyCode <= 70) ||  // 0-9
            event.keyCode == 8 || // backspace
            event.keyCode == 9 || // tab
            event.keyCode == 37 || // left
            event.keyCode == 39 || // right
            event.keyCode == 46 || // delete
            event.keyCode == 35 || // end
            event.keyCode == 36 || // home
            event.keyCode == 109 || // numpad minus
            event.keyCode == 173 || // minus
            (event.shiftKey && event.keyCode == 190) || // shift + :
            (event.shiftKey && event.keyCode == 9) || // shift + tab
            (event.ctrlKey && event.keyCode == 86) || // ctrl+v
            (event.ctrlKey && event.keyCode == 67) || // ctrl+c
            event.keyCode == 46) // delete
        {
            // Allow normal operation
        } else {
            // Prevent the rest
            event.preventDefault();
        }
    });

    $('#hostMac').on('input', function (e) {
        var e = $(this).val();
        var r = /([a-f0-9]{2})([a-f0-9]{2})/i,
            str = e.replace(/[^a-f0-9]/ig, "");
        while (r.test(str)) {
            str = str.replace(r, '$1' + ':' + '$2');
        }
        e = str.slice(0, 17).toLowerCase();

        $(this).val(e);
    });

    
    $('#breadcrumbCurrent').attr("href", window.location.pathname);

    </script>
    <script src="/js/fileUploadFs.js"></script>