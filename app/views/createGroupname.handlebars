<body>
    <div class="d-flex" id="wrapper">
        {{>sidebar}}
        <!-- Page Content -->
        <div id="page-content-wrapper">
            <!-- breadcrumb -->
            <div class="row">
                <div class="col-xs-12">
                    <div class="col-xs-12">
                        <ul class="breadcrumb">
                            <i class="icon icon-location"></i>
                            <li class="breadcrumb-item">
                                <a href="/add">Create groupname</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>


            <div class="container-fluid">
                <h1></h1>
                <div class="row">
                    <!-- posle naslova -->
                    <div class="col-xs-12">
                        <!-- lijevi stupac -->

                        <h4>Add group</h4>
                        <p>You have to use unique Groupname and Email!</p>

                        <form class="addForm" data-toggle="validator" role="form" method="POST" action="/add/insert">
                            <input type="hidden" name="_csrf" value="{{csrfToken}}">
                            <div class="form-row">
                                <label class="control-label" for="inputName">Group Name:</label>
                                <input class="form-control" data-error="Please enter username field" id="username"
                                    placeholder="Groupname" type="text" name="username" required />
                                <div class="help-block with-errors"></div>
                            </div>

                            <div class="form-row">
                                <label for="inputEmail" class="control-label">Contact Email:</label>
                                <input type="email" class="form-control" id="email" name="email" placeholder="Email"
                                    required>
                                <div class="help-block with-errors"></div>
                            </div>

                            <div class="form-row">
                                <button id="addBtn" type="submit" class="btn btn-primary">Add</button>
                                <button id="cancelBtn" type="button" class="btn btn-primary">Cancel</button>
                            </div>
                        </form>
                    </div>
                </div>
                <h1></h1>
                <div class="row">
                    <div class="col-xs-12">
                        <div class="listViewContainer">
                            <div class="addForm">
                            <h4>Existing groups</h4>
                            <input class="form-control" id="myInput" type="text" placeholder="Filter...">
                            <br>
                            </div>
                            <div id="userTblContainer">
                                <table id="tblUsrs" class="table table-bordered table-striped table-hover table-sm">
                                    <thead>
                                        <tr>
                                            <th class="col-md-2">Group Name</th>
                                            <th class="col-md-6">Contact Email</th>
                                            <th class="col-md-2" style="text-align: center;">Edit</th>
                                            <th class="col-md-2" style="text-align: center;">Delete</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        {{#each result}}
                                        <tr>
                                            <td class="col-md-2">{{uUsername}}</td>
                                            <td class="col-md-6">{{uEmail}}</td>
                                            <td class="col-md-2" style="text-align: center;"><button type="button" name="{{uUsername}}"
                                                    class="btn btn-link ed">edit</button>
                                            </td>
                                            <td class="col-md-2" style="text-align: center;"><button type="button" name="{{uUsername}}"
                                                    class="btn btn-link del">delete</button>
                                            </td>
                                        </tr>
                                        {{/each}}
                                    </tbody>
                                </table>
                            </div>
                            <p>Current groups stored in database.</p>
                        </div>
                    </div><!-- end of desni stupac -->
                </div><!-- end row -->


            </div>
        </div>

    </div>
    <!-- /container-fluid -->
    </div>
    <!-- /#page-content-wrapper -->
    </div>
    <!-- /#wrapper -->

    {{>logout}}

    <script type="application/javascript" nonce="{{nonce}}">
        {{#if errors}}
        {{#each errors}}
        {{#each this }}
        var divId = "{{param}}";
        var divOldValue = "{{value}}"
        var divWhatIsMessage = "{{msg}}";
        $('#' + divId).val(divOldValue);
        $('#' + divId).next().text(divWhatIsMessage);
        {{/each}}
                {{/each}}
                        {{/if}}

                                $("#myInput").on("keyup", function () {
                                    var value = $(this).val().toLowerCase();
                                    $("#tblUsrs tr").filter(function () {
                                        $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                                    });
                                });


                                $('#cancelBtn').on('click', function (e) {
                                    e.preventDefault();
                                    window.location.href = '/add';
                                });

                                (function () {
                                    'use strict';
                                    window.addEventListener('load', function () {
                                        // Fetch all the forms we want to apply custom Bootstrap validation styles to
                                        var forms = document.getElementsByClassName('needs-validation');
                                        // Loop over them and prevent submission
                                        var validation = Array.prototype.filter.call(forms, function (form) {
                                            form.addEventListener('submit', function (event) {
                                                if (form.checkValidity() === false) {
                                                    event.preventDefault();
                                                    event.stopPropagation();
                                                }
                                                form.classList.add('was-validated');
                                            }, false);
                                        });
                                    }, false);
                                })();

                                // create a div called confirm box
                                var confirmBoxDiv = "<div id='confirmBox'><div class='message'></div><span class='yes'>Yes</span><span class='no'>No</span></div>";
                                $('body').append(confirmBoxDiv);
                                $('#adduserlnk').css({ "background-color": "#f2f2f2" });

                                $('.ed, .del').on('click', function (e) {
                                    e.preventDefault();
                                    var thisBtn = $(this);
                                    var idUser = thisBtn.attr('name');
                                    var gotolink = "";


                                    var ajaxPostGet = "";
                                    var dataToSend;
                                    if (thisBtn.hasClass('ed')) {
                                        gotolink = "/edit/usr/byid/" + idUser; //http://192.168.162.18:50123/edit/byid/2
                                        ajaxPostGet = "GET";
                                        dataToSend = "";
                                        execAjax2(gotolink, ajaxPostGet, dataToSend);
                                    }
                                    if (thisBtn.hasClass('del')) {
                                        gotolink = "/delete";
                                        ajaxPostGet = "POST";
                                        dataToSend = {
                                            idUser: idUser,
                                            _csrf: $("[name='_csrf']").val()
                                        };
                                        var msgToUser = "Sure to delete user " + idUser + "?";
                                        // dialogbox
                                        doConfirm(msgToUser, $('body'), function yes() {
                                            //return;
                                            execAjax2(gotolink, ajaxPostGet, dataToSend);
                                        }, function no() {
                                            return;
                                        });

                                    }
                                });


                                function execAjax2(gotolink, ajaxPostGet, dataToSend) {
                                    $.ajax({
                                        url: gotolink,
                                        type: ajaxPostGet,

                                        complete: function () {
                                            //console.log(this.url);
                                        },

                                        data: dataToSend,
                                        success: function (data) {
                                            if (data == "deleted") {
                                                window.location.href = '/add';
                                            }
                                            else if (data == "error") {
                                                console.log("error deleting user");
                                                $.notify("Error deleting", "error");
                                            } else {
                                                window.location.href = gotolink;
                                            }

                                        },
                                        error: function (jqXhr, textStatus, err) {
                                            console.log("Error exec");
                                            console.log(jqXhr);
                                            $.notify("Error occured", "error");
                                        }
                                    });


                                }
    </script>
    <script src="/js/validator.js"></script>