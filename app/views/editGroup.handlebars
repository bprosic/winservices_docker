<body>
    <div class="d-flex" id="wrapper">

        {{>sidebar}}

        <!-- Page Content -->
        <div id="page-content-wrapper">
            <div class="row">
                <div class="col-xs-12">
                    <div class="col-xs-12">
                        <!-- breadcrumb -->
                        <ul class="breadcrumb">
                            <i class="icon icon-location"></i>
                            <li class="breadcrumb-item">
                                <a href="/add">Create groupname</a>
                            </li>
                            <li class="breadcrumb-item">
                                <a id="breadcrumbCurrent" href="#">Edit groupname</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="container-fluid">
                <h1></h1>
                <div class="row">
                    <div class="col-xs-12">
                        <h4>Change group name information:</h4>

                        <form class="addForm" data-toggle="validator" role="form" method="POST" action="/edit/usr/execedit">
                            <input type="hidden" name="_csrf" value="{{csrfToken}}">
                            {{#each userData}}
                            <div class="form-row">
                                <label for="inputUsername">Groupname</label>
                                <input type="text" class="form-control" id="inputUsername" name="inputUsername" placeholder="Username" value="{{uUsername}}">
                                <div class="help-block with-errors"></div>
                                <input type="text" class="form-control" id="currUsername" name="currUsername" value="{{uUsername}}" hidden>
                            </div>
                            <div class="form-row">
                                <label for="inputEmail">Email- anschprechpartner</label>
                                <input type="email" class="form-control" id="inputEmail" name="inputEmail" placeholder="Email" value="{{uEmail}}">
                                <div class="help-block with-errors"></div>
                            </div>
                            {{/each}}
            
                            <div class="form-row">
                                <button type="submit" id="btnSave" class="btn btn-primary">Save</button>
                                <button type="reset" id="btnCancel" class="btn btn-default">Cancel</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- /container-fluid -->
        </div>
        <!-- /#page-content-wrapper -->
    </div>
    <!-- /#wrapper -->



{{>logout}}

    <script type="application/javascript" nonce="{{nonce}}">
        $('#adduserlnk').css({"background-color":"#f2f2f2"});
        var userName = "";
        {{#each userData}}
            userName = "{{uUsername}}";
        {{/each}}

        {{#if errors}}
            {{#each errors}}
                var divId = "{{this.param}}"; // inputUsername
                var divOldValue = "{{this.value}}"
                var divWhatIsMessage = "{{this.msg}}";
                $('#' + divId).val(divOldValue);
                $('#' + divId).next().text(divWhatIsMessage);
            {{/each}}
        {{/if}}

        
        $('#btnCancel').on('click', function (e) {
            e.preventDefault();
            window.location.href = window.history.back();
        });

        $('#breadcrumbCurrent').attr("href", window.location.pathname);
        
        
    

    </script>
    <script src="/js/validator.js"></script>
    